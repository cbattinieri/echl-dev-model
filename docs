const LGMAP     = {ncaa:'NCAA',ohl:'OHL',whl:'WHL',qmjhl:'QMJHL',usports:'USports'};

const PROJ_OPTS_F = [
  ['1st_liner','⭐ 1st Liner'],['2nd_liner','2nd Liner'],
  ['bottom_six_two_way','🔵 Bottom Six / Two-Way'],
  ['checking','🟠 Checking'],['fringe','🔴 Fringe']
