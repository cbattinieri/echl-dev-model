const PROJ_OPTS_D = [
  ['number_1','⭐ Number One D'],['top_pair','Top Pair'],
  ['middle_pair','🔵 Middle Pair'],
  ['bottom_pair','🟠 Bottom Pair'],['fringe','🔴 Fringe']
