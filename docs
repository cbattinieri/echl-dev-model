function curData()   { return POS==='F' ? P : D; }
function curLabels() { return POS==='F' ? PLABELS_F : PLABELS_D; }
function curColors() { return POS==='F' ? PCOLORS_F : PCOLORS_D; }
function curLbls()   { return POS==='F' ? PLBLS_F   : PLBLS_D; }

function probBar(ps) {
  const clrs = curColors(), lbls = curLbls();
  const segs = ps.map((v,i) => v>=1
    ? `<div class="pseg" style="flex:${v};background:${clrs[i]}" title="${lbls[i]}: ${v.toFixed(1)}%"></div>`
    : '').join('');
  const top = Math.max(...ps), ti = ps.indexOf(top);
  return `<div class="prow"><div class="pbar">${segs}</div><div class="plbl">${lbls[ti]}: ${top.toFixed(1)}%</div></div>`;
}
function pmClass(v) { return v>0.15?'pm-pos':v<-0.15?'pm-neg':'pm-neu'; }
function pmSign(v)  { return (v>0?'+':'')+v.toFixed(2); }

// ── PAGE + POSITION NAV ────────────────────────────────────────────────────
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const tabs = document.querySelectorAll('.nav-tab');
  if (id==='players') { tabs[0].classList.add('active'); document.getElementById('pos-bar').style.display=''; }
  if (id==='guide')   { tabs[1].classList.add('active'); document.getElementById('pos-bar').style.display='none'; }
}

function setPos(pos) {
  POS = pos;
  document.getElementById('btn-fwd').classList.toggle('active',  pos==='F');
  document.getElementById('btn-dman').classList.toggle('active', pos==='D');
  // Swap legend
  const leg = document.getElementById('proj-legend');
  if (pos === 'F') {
    leg.innerHTML = `
      <div class="pleg"><div class="pleg-dot" style="background:var(--c1)"></div>1st Liner</div>
      <div class="pleg"><div class="pleg-dot" style="background:#475569"></div>2nd Liner</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cb)"></div>Bottom 6 / Two-Way</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cc)"></div>Checking</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cf)"></div>Fringe</div>`;
  } else {
    leg.innerHTML = `
      <div class="pleg"><div class="pleg-dot" style="background:var(--c1)"></div>Number One D</div>
      <div class="pleg"><div class="pleg-dot" style="background:#475569"></div>Top Pair</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cb)"></div>Middle Pair</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cc)"></div>Bottom Pair</div>
      <div class="pleg"><div class="pleg-dot" style="background:var(--cf)"></div>Fringe</div>`;
  }
  // Reset projection filter options
  const projOpts = pos==='F' ? PROJ_OPTS_F : PROJ_OPTS_D;
  const sel = document.getElementById('s-proj');
  sel.innerHTML = '<option value="">All Projections</option>' +
    projOpts.map(([v,l]) => `<option value="${v}">${l}</option>`).join('');
  buildTeams();
  renderCards();
  render();
}

// ── FILTER + SORT ──────────────────────────────────────────────────────────
function buildTeams() {
  const fl = document.getElementById('s-league').value;
  const sel = document.getElementById('s-team');
  const prev = sel.value;
  const teams = [...new Set(
    curData().filter(p => !fl || p.league === fl).map(p => p.team)
  )].sort();
  sel.innerHTML = '<option value="">All Teams</option>' +
    teams.map(t => `<option value="${t}"${t===prev?' selected':''}>${t}</option>`).join('');
  if (!teams.includes(prev)) sel.value = '';
}

function getFiltered() {
  const q   = document.getElementById('s-search').value.toLowerCase();
  const fl  = document.getElementById('s-league').value;
  const ft  = document.getElementById('s-team').value;
  const fp  = document.getElementById('s-proj').value;
  const ff  = document.getElementById('s-flags').value;
  const gpm = parseInt(document.getElementById('s-gp').value) || 0;
  const pm  = MODEL==='pm';
  return curData().filter(p => {
    if (q   && !p.player.toLowerCase().includes(q)) return false;
    if (fl  && p.league !== fl) return false;
    if (ft  && p.team   !== ft) return false;
    if (fp  && (pm ? p.pm_proj : p.ppg_proj) !== fp) return false;
    if (ff==='eligible' && !p.eligible) return false;
    if (ff==='sample'   && !p.sample)   return false;
    if (ff==='diff'     && !p.model_diff) return false;
    if (gpm > 0 && p.gp < gpm) return false;
    return true;
  });
}
function getSorted(d) {
  return [...d].sort((a,b)=>{
    let av=a[SCOL],bv=b[SCOL];
    if(typeof av==='string'){av=av.toLowerCase();bv=bv.toLowerCase();}
    if(av<bv) return SASC?-1:1;
    if(av>bv) return SASC?1:-1;
    return 0;
  });
}

// ── RENDER ─────────────────────────────────────────────────────────────────
function render() {
  const data   = getSorted(getFiltered());
  const pm     = MODEL==='pm';
  const labels = curLabels();
  const tbody  = document.getElementById('tbody');
  const empty  = document.getElementById('empty');
  document.getElementById('cnt').textContent = data.length;
  document.getElementById('th-pm_pg').style.display = pm ? '' : 'none';
  if(!data.length){tbody.innerHTML='';empty.style.display='';return;}
  empty.style.display='none';
  tbody.innerHTML = data.map(p=>{
    const proj  = pm ? p.pm_proj  : p.ppg_proj;
    const probs = pm ? p.pm_p     : p.ppg_p;
    const diff  = pm && p.model_diff;
    return `<tr>
      <td>
        <div class="pcell">
          <div class="pname">${p.player}</div>
          <div class="pmeta">
            <span class="ptag">${p.pos}</span>
            <div class="flags">
              ${p.eligible?`<span class="flag fe" title="ECHL Eligible — player appears to be in their final eligible feeder season.">✓ ECHL</span>`:''}
              ${p.sample?`<span class="flag fs" title="Sample Flag — current-season GP is below the 25%-of-season reliability floor.">⚠ Sample</span>`:''}
              ${diff?`<span class="flag fd" title="Model Disagrees — the PPG + Per-Game ± model gives a different projection. Worth a closer look.">⚡ Diff</span>`:''}
            </div>
          </div>
        </div>
      </td>
      <td>
        <div style="display:flex;flex-direction:column;gap:3px">
          <span class="lbadge lg-${p.league}">${LGMAP[p.league]||p.league}</span>
          <span style="color:var(--muted);font-size:11px">${p.team}</span>
        </div>
      </td>
      <td class="num">${p.gp}</td>
      <td class="num">${p.ppg.toFixed(2)}</td>
      <td class="num"><span class="nhle-v">${p.nhle.toFixed(2)}</span></td>
      ${pm?`<td class="num"><span class="${pmClass(p.pm_pg)}" title="Per-game ±: ${p.pm_pg>0.15?'Positive':p.pm_pg<-0.15?'Negative':'Neutral'}">${pmSign(p.pm_pg)}</span></td>`:''}
      <td><span class="pbadge p-${proj}">${labels[proj]||proj}</span></td>
      <td>${probBar(probs)}</td>
      <td><span class="fhist" title="${p.feeder} · ${p.szn} total feeder season${p.szn!==1?'s':''}">${p.feeder}</span></td>
    </tr>`;
  }).join('');
}

function renderCards() {
  const data = curData();
  const el   = data.filter(p=>p.eligible).length;
  const top1 = POS==='F'
    ? data.filter(p=>p.ppg_proj==='1st_liner').length
    : data.filter(p=>p.ppg_proj==='number_1').length;
  const dif  = data.filter(p=>p.model_diff).length;
  const lbl1 = POS==='F' ? '⭐ Projected 1st Liners (PPG)' : '⭐ Projected #1 D (PPG)';
  document.getElementById('cards').innerHTML = `
    <div class="card"><div class="card-val">${data.length}</div><div class="card-lbl">Total Players Scored</div></div>
    <div class="card c-accent"><div class="card-val">${el}</div><div class="card-lbl">✓ ECHL Eligible</div></div>
    <div class="card c-gold"><div class="card-val">${top1}</div><div class="card-lbl">${lbl1}</div></div>
    <div class="card c-purple"><div class="card-val">${dif}</div><div class="card-lbl">⚡ Model Disagreements</div></div>`;
}

// ── CONTROLS ───────────────────────────────────────────────────────────────
function setModel(m) {
  MODEL = m;
  document.getElementById('btn-ppg').classList.toggle('active', m==='ppg');
  document.getElementById('btn-pm').classList.toggle('active',  m==='pm');
  document.getElementById('pm-strip').classList.toggle('show',   m==='pm');
  render();
}

function sortBy(col) {
  SASC = (SCOL===col) ? !SASC : (col==='player');
  SCOL = col;
  document.querySelectorAll('thead th').forEach(th=>{
    th.classList.remove('sorted');
    const si=th.querySelector('.si');
    if(si) si.textContent='↕';
  });
  const th = document.getElementById('th-'+col);
  if(th){ th.classList.add('sorted'); const si=th.querySelector('.si'); if(si) si.textContent=SASC?'↑':'↓'; }
  render();
}

function resetFilters() {
  document.getElementById('s-search').value = '';
  document.getElementById('s-league').value = '';
  document.getElementById('s-proj').value   = '';
  document.getElementById('s-flags').value  = '';
  document.getElementById('s-gp').value     = 0;
  document.getElementById('gp-val').textContent = '0';
  buildTeams();
  render();
}

// ── INIT ───────────────────────────────────────────────────────────────────
setPos('F');   // populates projection dropdown + teams, renders cards + table
showPage('players');
</script>
