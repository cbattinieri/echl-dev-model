        <div class="nhle-eg-item">
          <div class="val">1.00</div>
          <div class="lbl">PPG in NCAA</div>
          <div class="arr">↓</div>
          <div class="nhle">0.19</div>
          <div class="lbl">NHLe PPG</div>
